{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BeautyManagerPro",
  "version": "0.6.2",
  "identifier": "com.beautymanager.pro",
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/IDGioX/beauty-manager-pro/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ2MzkyRTNCMTY3OUE4RDEKUldUUnFIa1dPeTQ1MWpKdXlrMXVZRHowY2xLYnMyajk1azNkUVhTRFpkeExyTkxXYUFJRFJSby8K"
    }
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Beauty Manager Pro",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https://ipc.localhost https://api.github.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright © 2025 Beauty Manager Pro",
    "category": "Business",
    "shortDescription": "Gestionale per centri estetici",
    "longDescription": "Software completo per la gestione di centri estetici, spa e saloni di bellezza. Include gestione clienti, agenda appuntamenti, magazzino, comunicazioni e analytics avanzate.",
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "resources": []
  }
}
